# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it, and never paste real values
# into this file, a commit message, or a chat/log.

# --- Required in every environment (browser-safe) -------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Canonical site URL, used for absolute metadata/OG URLs. Defaults to
# http://localhost:3000 if unset, so this is required in production only.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC_) -----------------
# Full-privilege Supabase key, bypasses Row Level Security. Used only in
# server-side code (API routes, the question-factory generator). Never send
# this to the browser, never log it, never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# AI Question Factory (admin-only feature). Optional — the app runs fine
# without it; the "Generate Questions" admin tool will just be unavailable.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Legacy/local-development-only shared-secret admin gate. Real deployments
# should rely on Supabase Auth admin accounts (see ADMIN.md) instead — this
# is kept only as a documented local-dev fallback and should NOT be set in
# production once Supabase Auth admin accounts are configured.
QUESTION_ADMIN_SECRET=
